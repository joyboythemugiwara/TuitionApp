{
  "name": "backend",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "db:generate": "bun db:generate:public && bun db:generate:tenant",
    "db:generate:public": "drizzle-kit generate --config=drizzle.public.config.ts",
    "db:generate:tenant": "drizzle-kit generate --config=drizzle.tenant.config.ts",
    "db:migrate:public": "drizzle-kit migrate --config=drizzle.public.config.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@faker-js/faker": "10.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "tsconfig-paths": "4.2.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1075.0",
    "@aws-sdk/s3-request-presigner": "3.1075.0",
    "@elysia/server-timing": "^1.4.1",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@sentry/bun": "10.67.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node-cron": "3.0.11",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.1",
    "dayjs": "^1.11.21",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "elysia-rate-limit": "^4.6.2",
    "envsafe": "^2.0.3",
    "firebase": "12.15.0",
    "firebase-admin": "14.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nanoid": "^5.1.16",
    "node-cron": "4.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "posthog-node": "5.46.0",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "resend": "6.16.0",
    "tsyringe": "^4.10.0",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "jwks-rsa": "3.0.1"
  }
}